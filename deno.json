{
  "allowScripts": [
    "npm:core-js"
  ],
  "imports": {
    "@std/cli": "jsr:@std/cli@^1.0.31",
    "@std/path": "jsr:@std/path@^1.1.6",
    "cheerio": "npm:cheerio@latest",
    "jsonresume-theme-elegant": "npm:jsonresume-theme-elegant@1.9.0",
    "jsonresume-theme-even": "npm:jsonresume-theme-even@0.22.0",
    "jsonresume-theme-paper": "npm:jsonresume-theme-paper@0.5.0",
    "resume-cli": "npm:resume-cli@latest",
    "turndown": "npm:turndown@latest"
  },
  "nodeModulesDir": "auto",
  "permissions": {
    "export:html": {
      "env": true,
      "read": true,
      "sys": true,
      "write": true
    },
    "export:markdown": {
      "env": true,
      "read": true,
      "sys": true,
      "write": true
    },
    "export:pdf": {
      "env": true,
      "net": true,
      "read": true,
      "run": true,
      "sys": true,
      "write": true
    }
  },
  "tasks": {
    "export": "deno task export:html && deno task export:markdown && deno task export:pdf",
    "export:html": "deno run -P='export:html' resume-cli/resume export --resume=assets/resume.json --theme=elegant assets/resume.html",
    "export:markdown": "deno run -P='export:markdown' resume-cli/resume export --resume=assets/resume.json --theme=even /tmp/readme.html && deno run -P='export:markdown' main.ts --from=/tmp/readme.html --to=readme.md",
    "export:pdf": "PUPPETEER_EXECUTABLE_PATH='/var/lib/flatpak/exports/bin/com.brave.Browser' deno run -P='export:pdf' resume-cli/resume export --resume=assets/resume.json --theme=paper assets/resume.pdf"
  }
}
